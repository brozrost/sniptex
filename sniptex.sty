\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{sniptex}[2026/04/24 SnipTeX - Package for including tagged code snippets.]

\RequirePackage{iftex}
\RequirePackage{xcolor}
\RequirePackage{minted}
\RequirePackage{tcolorbox}
\RequirePackage{fontspec}

\setmonofont{Menlo}

\ifLuaTeX
\else
  \PackageError{sniptex}{SnipTeX requires LuaLaTeX}{Use lualatex instead}
\fi

\usemintedstyle{github-dark}

\definecolor{sniptexbg}{HTML}{161B22}
\definecolor{sniptexline}{HTML}{6E7681}

\renewcommand{\theFancyVerbLine}{
    \scriptsize\textcolor{sniptexline}{\arabic{FancyVerbLine}}
}

\def\sniptexfirstline{1}
\def\sniptexlastline{1}

\newread\sniptexlinefile

\newlength{\sniptexnumberwidth}
\newlength{\sniptexleftpadding}

\newcommand{\sniptexbox}[3]{
    \begin{tcolorbox}[
        colback=sniptexbg,
        colframe=sniptexbg,
        boxrule=0pt,
        arc=3mm,
        left=\sniptexleftpadding,
        right=3mm,
        top=2mm,
        bottom=2mm,
        boxsep=0pt
    ]
    \inputminted[
        linenos,
        firstnumber=\number\numexpr\sniptexfirstline\relax,
        numbersep=10pt,
        fontsize=\footnotesize,
        breaklines,
        tabsize=4,
        breaksymbolleft={},
        breaksymbolright={},
        breakindent=1.5em,
        breakautoindent=true,
        #3
    ]{#2}{#1}
    \end{tcolorbox}
}

\newcounter{sniptexsnippet}

\newcommand{\IncludeCode}[4][]{
  \stepcounter{sniptexsnippet}

  \edef\sniptexoutfile{sniptex-\arabic{sniptexsnippet}.tmp}

  \immediate\write18{sniptex -s "#2" -t "#3" -o "\sniptexoutfile"}

  \openin\sniptexlinefile=\sniptexoutfile.meta
  \read\sniptexlinefile to \sniptexfirstline
  \read\sniptexlinefile to \sniptexlastline
  \closein\sniptexlinefile
  
  \settowidth{\sniptexnumberwidth}{\scriptsize\texttt{\sniptexlastline}}
  \setlength{\sniptexleftpadding}{\sniptexnumberwidth}
  \addtolength{\sniptexleftpadding}{18pt}

  \sniptexbox{\sniptexoutfile}{#4}{#1}

  \immediate\write18{rm -f "\sniptexoutfile"}
  \immediate\write18{rm -f "\sniptexoutfile.meta"}
}